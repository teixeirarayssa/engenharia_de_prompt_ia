                <li><a href="#" onclick="showSection('musicas'); return false;">🎵 Músicas</a></li>
                <li><a href="#" onclick="showSection('salmos'); return false;">📖 Salmos</a></li>
                <li><a href="#" onclick="showSection('rezas'); return false;">🙏 Rezas</a></li>
                <li><a href="#" onclick="showSection('terco'); return false;">📿 Terço</a></li>
                <li><a href="#" onclick="showSection('musica-missa'); return false;">🎼 Música da Missa</a></li>
