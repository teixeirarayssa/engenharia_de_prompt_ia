<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Católico - Músicas, Salmos e Rezas</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-color: #1a472a;
            --secondary-color: #d4af37;
            --tertiary-color: #8b6f47;
            --light-bg: #f5f3f0;
            --text-dark: #2c2c2c;
            --text-light: #666;
            --border-color: #e0d5c7;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: var(--text-dark);
            background-color: var(--light-bg);
        }

        /* NAVBAR */
        .navbar {
            background: linear-gradient(135deg, var(--primary-color) 0%, #0d2818 100%);
            padding: 1rem 0;
            box-shadow: var(--shadow-lg);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--secondary-color);
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .nav-menu a {
            color: white;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            padding: 0.5rem 1rem;
            border-radius: 4px;
        }

        .nav-menu a:hover {
            color: var(--secondary-color);
            background-color: rgba(212, 175, 55, 0.1);
            transform: translateY(-2px);
        }

        /* CONTAINER */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* SECTIONS */
        .section {
            display: none;
            padding: 3rem 0;
            min-height: 80vh;
            animation: fadeIn 0.5s ease;
        }

        .section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section h2 {
            color: var(--primary-color);
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            text-align: center;
        }

        .subheading {
            text-align: center;
            color: var(--text-light);
            font-size: 1.1rem;
            margin-bottom: 2rem;
        }

        /* HERO SECTION */
        .hero {
            text-align: center;
            padding: 3rem;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--tertiary-color) 100%);
            border-radius: 10px;
            color: white;
            margin-bottom: 3rem;
            box-shadow: var(--shadow-lg);
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            opacity: 0.95;
        }

        /* STATS */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .stat-box {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: var(--shadow);
            transition: all 0.3s ease;
            border-top: 4px solid var(--secondary-color);
        }

        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .stat-box h3 {
            color: var(--primary-color);
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .stat-box p {
            color: var(--text-light);
        }

        /* SEARCH BOX */
        .search-box {
            margin-bottom: 2rem;
            text-align: center;
        }

        .search-box input {
            width: 100%;
            max-width: 400px;
            padding: 0.8rem 1.2rem;
            border: 2px solid var(--border-color);
            border-radius: 25px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
        }

        /* CARDS GRID */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .card {
            background: white;
            border-radius: 10px;
            padding: 2rem;
            box-shadow: var(--shadow);
            transition: all 0.3s ease;
            border-left: 4px solid var(--secondary-color);
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .card h3 {
            color: var(--primary-color);
            margin-bottom: 1rem;
            font-size: 1.3rem;
        }

        .card p {
            color: var(--text-light);
            margin-bottom: 1rem;
            line-height: 1.5;
        }

        .card audio {
            width: 100%;
            margin-bottom: 1rem;
            border-radius: 5px;
        }

        /* BUTTONS */
        .btn {
            padding: 0.7rem 1.5rem;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-weight: 600;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color), var(--tertiary-color));
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(26, 71, 42, 0.3);
        }

        .btn-small {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            background-color: var(--secondary-color);
            color: var(--primary-color);
        }

        .btn-small:hover {
            background-color: #e6c75e;
        }

        .btn-filter {
            background-color: var(--light-bg);
            color: var(--primary-color);
            border: 2px solid var(--secondary-color);
            padding: 0.6rem 1.2rem;
        }

        .btn-filter:hover {
            background-color: var(--secondary-color);
            color: var(--primary-color);
        }

        .btn-remover {
            background-color: #d32f2f;
            color: white;
            padding: 0.4rem 0.8rem;
            font-size: 0.85rem;
        }

        .btn-remover:hover {
            background-color: #b71c1c;
        }

        .btn-full {
            width: 100%;
        }

        /* ACCORDION */
        .accordion {
            margin: 2rem 0;
        }

        .accordion-item {
            background: white;
            margin-bottom: 1rem;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .accordion-header {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--tertiary-color) 100%);
            color: white;
            padding: 1.5rem;
            cursor: pointer;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .accordion-header:hover {
            background: linear-gradient(135deg, #0d2818 0%, #6d5635 100%);
        }

        .accordion-header::after {
            content: '▼';
            font-size: 0.8rem;
            transition: transform 0.3s ease;
        }

        .accordion-header.active::after {
            transform: rotate(180deg);
        }

        .accordion-content {
            display: none;
            padding: 2rem;
            background: white;
        }

        .accordion-item.active .accordion-content {
            display: block;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .accordion-content p {
            line-height: 1.8;
            color: var(--text-dark);
            margin-bottom: 1rem;
        }

        /* REZAS */
        .rezas-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .reza-box {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: var(--shadow);
            border-left: 4px solid var(--primary-color);
            transition: all 0.3s ease;
        }

        .reza-box:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .reza-box h3 {
            color: var(--primary-color);
            margin-bottom: 1.5rem;
            font-size: 1.3rem;
        }

        .reza-texto {
            background: var(--light-bg);
            padding: 1.5rem;
            border-radius: 5px;
            margin-bottom: 1rem;
            line-height: 1.8;
        }

        .reza-texto p {
            color: var(--text-dark);
            font-style: italic;
        }

        /* FORMS */
        .form-container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--primary-color);
            font-weight: 600;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.8rem;
            border: 2px solid var(--border-color);
            border-radius: 5px;
            font-size: 1rem;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.2);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        /* MISSAS */
        .missas-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .list-container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: var(--shadow);
        }

        .filter-buttons {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .missas-list {
            max-height: 600px;
            overflow-y: auto;
        }

        .missa-item {
            background: var(--light-bg);
            padding: 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--secondary-color);
            transition: all 0.3s ease;
        }

        .missa-item:hover {
            box-shadow: var(--shadow);
            transform: translateX(5px);
        }

        .missa-item h4 {
            color: var(--primary-color);
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }

        .missa-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
            color: var(--text-dark);
        }

        .missa-info div {
            padding: 0.5rem;
        }

        .missa-descricao {
            background: white;
            padding: 1rem;
            border-radius: 5px;
            margin-bottom: 1rem;
            color: var(--text-dark);
        }

        .info-vazia {
            text-align: center;
            color: var(--text-light);
            padding: 2rem;
            font-style: italic;
        }

        /* TERÇO */
        .terco-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .step-box {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: var(--shadow);
            border-top: 4px solid var(--secondary-color);
            transition: all 0.3s ease;
        }

        .step-box:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .step-box h4 {
            color: var(--primary-color);
            margin-bottom: 1rem;
            font-size: 1.2rem;
        }

        .step-box p {
            color: var(--text-dark);
            line-height: 1.8;
        }

        /* MUSICAL DA MISSA */
        .musica-rito {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            margin-bottom: 2rem;
            box-shadow: var(--shadow);
            border-left: 5px solid var(--secondary-color);
        }

        .musica-rito h4 {
            color: var(--primary-color);
            margin-bottom: 1rem;
            font-size: 1.3rem;
        }

        .musica-rito-descricao {
            background: var(--light-bg);
            padding: 1rem;
            border-radius: 5px;
            margin-bottom: 1.5rem;
            color: var(--text-dark);
            font-style: italic;
        }

        .musicas-rito-list {
            display: grid;
            gap: 1rem;
        }

        .musica-item {
            background: var(--light-bg);
            padding: 1rem;
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .musica-info {
            flex: 1;
        }

        .musica-nome {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.3rem;
        }

        .musica-autor {
            font-size: 0.9rem;
            color: var(--text-light);
            font-style: italic;
        }

        .musica-botoes {
            display: flex;
            gap: 0.5rem;
        }

        .btn-usar {
            background-color: #4caf50;
            color: white;
            padding: 0.5rem 1rem;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-usar:hover {
            background-color: #45a049;
        }

        .resumo-musical {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--tertiary-color) 100%);
            color: white;
            padding: 2rem;
            border-radius: 10px;
            margin-top: 3rem;
            box-shadow: var(--shadow-lg);
        }

        .resumo-musical h3 {
            margin-bottom: 1.5rem;
            font-size: 1.5rem;
        }

        .resumo-rito {
            background: rgba(255, 255, 255, 0.1);
            padding: 1rem;
            border-radius: 5px;
            margin-bottom: 1rem;
        }

        .resumo-rito-titulo {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .resumo-musicas {
            padding-left: 1rem;
            font-size: 0.95rem;
        }

        .resumo-musica-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            align-items: center;
        }

        .botoes-exportacao {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        /* FOOTER */
        .footer {
            background: var(--primary-color);
            color: white;
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
        }

        .footer-content p {
            margin: 0.5rem 0;
        }

        /* RESPONSIVO */
        @media (max-width: 768px) {
            .navbar-container {
                flex-direction: column;
                gap: 1rem;
            }

            .nav-menu {
                gap: 1rem;
            }

            .logo {
                font-size: 1.5rem;
            }

            .section h2 {
                font-size: 1.8rem;
            }

            .hero h1 {
                font-size: 1.8rem;
            }

            .missas-content {
                grid-template-columns: 1fr;
            }

            .missa-info {
                grid-template-columns: 1fr;
            }

            .cards-grid {
                grid-template-columns: 1fr;
            }

            .rezas-container {
                grid-template-columns: 1fr;
            }

            .terco-steps {
                grid-template-columns: 1fr;
            }

            .filter-buttons {
                flex-direction: column;
            }

            .filter-buttons .btn {
                width: 100%;
            }

            .musica-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .musica-botoes {
                width: 100%;
            }

            .musica-botoes .btn-usar {
                width: 100%;
            }

            .botoes-exportacao {
                flex-direction: column;
            }

            .botoes-exportacao .btn {
                width: 100%;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 0 1rem;
            }

            .nav-menu {
                gap: 0.5rem;
                font-size: 0.9rem;
            }

            .nav-menu a {
                padding: 0.3rem 0.6rem;
            }

            .hero {
                padding: 2rem 1rem;
            }

            .hero h1 {
                font-size: 1.5rem;
            }

            .btn {
                padding: 0.6rem 1rem;
                font-size: 0.9rem;
            }

            .accordion-header {
                font-size: 1rem;
                padding: 1rem;
            }

            .form-container,
            .list-container {
                padding: 1rem;
            }
        }

        /* SCROLL BAR CUSTOMIZADO */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--light-bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--secondary-color);
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary-color);
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="navbar-container">
            <div class="logo">✝️ Portal Católico</div>
            <ul class="nav-menu">
