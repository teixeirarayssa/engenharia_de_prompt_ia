    <script>
        // Variáveis globais
        let organizacaoMusical = {};
        let missasAgendadas = JSON.parse(localStorage.getItem('missasAgendadas')) || [];

        // Alternar seções
        function showSection(sectionId) {
            const sections = document.querySelectorAll('.section');
            sections.forEach(section => {
                section.classList.remove('active');
            });

            const selectedSection = document.getElementById(sectionId);
            if (selectedSection) {
                selectedSection.classList.add('active');
                window.scrollTo(0, 0);
            }
        }

        // Favoritar
        function favoritar(id) {
            const favoritos = JSON.parse(localStorage.getItem('favoritos')) || [];
            
            if (favoritos.includes(id)) {
                favoritos.splice(favoritos.indexOf(id), 1);
                alert('❌ Removido dos favoritos!');
            } else {
                favoritos.push(id);
                alert('✅ Adicionado aos favoritos!');
            }
            
            localStorage.setItem('favoritos', JSON.stringify(favoritos));
        }

        // Accordion para salmos
        function toggleAccordion(element) {
            const parent = element.parentElement;
            parent.classList.toggle('active');
            element.classList.toggle('active');
        }

        // Pesquisar música
        function pesquisarMusica() {
            const input = document.getElementById('searchMusica').value.toLowerCase();
            const cards = document.querySelectorAll('#gridMusicas .card');
            
            cards.forEach(card => {
                const h3 = card.querySelector('h3').textContent.toLowerCase();
                const p = card.querySelector('p').textContent.toLowerCase();
                
                if (h3.includes(input) || p.includes(input)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Adicionar música à organização
        function adicionarMusica(rito, musica, autor) {
            if (!organizacaoMusical[rito]) {
                organizacaoMusical[rito] = [];
            }
            
            organizacaoMusical[rito].push({ musica, autor });
            atualizarResumo();
            alert(`✅ "${musica}" adicionada ao ${rito}!`);
        }

        // Remover música
        function removerMusica(rito, index) {
            if (organizacaoMusical[rito]) {
                organizacaoMusical[rito].splice(index, 1);
                if (organizacaoMusical[rito].length === 0) {
                    delete organizacaoMusical[rito];
                }
                atualizarResumo();
            }
        }

        // Atualizar resumo
        function atualizarResumo() {
            const resumoDiv = document.getElementById('resumoMusical');
            
            if (Object.keys(organizacaoMusical).length === 0) {
                resumoDiv.innerHTML = '<p style="text-align: center; font-style: italic;">Selecione as músicas acima para visualizar o resumo aqui</p>';
                return;
            }

            let html = '';
            const ritos = ['Canto de Entrada', 'Glória (Kyrie)', 'Aclamação do Evangelho', 'Salmo Responsorial', 'Canto das Oferendas', 'Santo (Sanctus)', 'Canto da Comunhão', 'Canto de Recessão/Saída'];
            
            ritos.forEach(rito => {
                if (organizacaoMusical[rito]) {
                    html += `<div class="resumo-rito">
                                <div class="resumo-rito-titulo">${rito}</div>
                                <div class="resumo-musicas">`;
                    
                    organizacaoMusical[rito].forEach((item, index) => {
                        html += `<div class="resumo-musica-item">
                                    <span>${item.musica} - ${item.autor}</span>
                                    <button class="btn-remover" onclick="removerMusica('${rito}', ${index})">✕ Remover</button>
                                </div>`;
                    });
                    
                    html += `</div></div>`;
                }
            });
            
            resumoDiv.innerHTML = html;
        }

        // Exportar para TXT
        function exportarTxt() {
            if (Object.keys(organizacaoMusical).length === 0) {
                alert('❌ Nenhuma música selecionada!');
                return;
            }

            let conteudo = '📋 ORGANIZAÇÃO MUSICAL DA MISSA\n';
            conteudo += '================================\n\n';
            
            const ritos = ['Canto de Entrada', 'Glória (Kyrie)', 'Aclamação do Evangelho', 'Salmo Responsorial', 'Canto das Oferendas', 'Santo (Sanctus)', 'Canto da Comunhão', 'Canto de Recessão/Saída'];
            
            ritos.forEach(rito => {
                if (organizacaoMusical[rito]) {
                    conteudo += `\n${rito}:\n`;
                    organizacaoMusical[rito].forEach(item => {
                        conteudo += `  • ${item.musica} (${item.autor})\n`;
                    });
                }
            });

            const blob = new Blob([conteudo], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'organizacao-musical-missa.txt';
            a.click();
            URL.revokeObjectURL(url);
        }

        // Exportar para JSON
        function exportarJSON() {
            if (Object.keys(organizacaoMusical).length === 0) {
                alert('❌ Nenhuma música selecionada!');
                return;
            }

            const blob = new Blob([JSON.stringify(organizacaoMusical, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'organizacao-musical-missa.json';
            a.click();
            URL.revokeObjectURL(url);
        }

        // Limpar seleções
        function limparSelecoes() {
            if (confirm('Tem certeza que deseja limpar todas as seleções?')) {
                organizacaoMusical = {};
                atualizarResumo();
                alert('🔄 Seleções limpas!');
            }
        }

        // Agendar missa
        function agendarMissa(event) {
            event.preventDefault();

            const dataMissa = document.getElementById('dataMissa').value;
            const horaMissa = document.getElementById('horaMissa').value;
            const localMissa = document.getElementById('localMissa').value;
            const sacerdote = document.getElementById('sacerdote').value;
            const tipoMissa = document.getElementById('tipoMissa').value;
            const descricaoMissa = document.getElementById('descricaoMissa').value;

            if (!dataMissa || !horaMissa || !localMissa || !sacerdote || !tipoMissa) {
                alert('⚠️ Por favor, preencha todos os campos obrigatórios!');
                return;
            }

            const missa = {
                id: Date.now(),
                data: dataMissa,
                hora: horaMissa,
                local: localMissa,
                sacerdote: sacerdote,
                tipo: tipoMissa,
                descricao: descricaoMissa
            };

            missasAgendadas.push(missa);
            localStorage.setItem('missasAgendadas', JSON.stringify(missasAgendadas));
            
            document.getElementById('formMissa').reset();
            exibirMissas();
            alert('✅ Missa agendada com sucesso!');
        }

        // Exibir missas
        function exibirMissas() {
            const listaMissas = document.getElementById('listaMissas');
            
            if (missasAgendadas.length === 0) {
                listaMissas.innerHTML = '<p class="info-vazia">Nenhuma missa agendada.</p>';
                return;
            }

            let html = '';
            missasAgendadas.forEach(missa => {
                const dataFormatada = new Date(missa.data).toLocaleDateString('pt-BR');
                html += `
                    <div class="missa-item">
                        <h4>${missa.tipo}</h4>
                        <div class="missa-info">
                            <div>📅 <strong>Data:</strong> ${dataFormatada}</div>
                            <div>🕐 <strong>Hora:</strong> ${missa.hora}</div>
                        </div>
                        <div class="missa-info">
                            <div>📍 <strong>Local:</strong> ${missa.local}</div>
                            <div>👨‍⛪ <strong>Sacerdote:</strong> ${missa.sacerdote}</div>
                        </div>
                        ${missa.descricao ? `<div class="missa-descricao"><strong>Notas:</strong> ${missa.descricao}</div>` : ''}
                        <button class="btn-remover" onclick="removerMissa(${missa.id})">✕ Remover</button>
                    </div>
                `;
            });

            listaMissas.innerHTML = html;
        }

        // Remover missa
        function removerMissa(id) {
            if (confirm('Tem certeza que deseja remover esta missa?')) {
                missasAgendadas = missasAgendadas.filter(m => m.id !== id);
                localStorage.setItem('missasAgendadas', JSON.stringify(missasAgendadas));
                exibirMissas();
                alert('❌ Missa removida!');
            }
        }

        // Filtrar missas por tipo
        function filtrarMissasPorTipo(tipo) {
            const listaMissas = document.getElementById('listaMissas');
            const missasFiltradas = missasAgendadas.filter(m => m.tipo === tipo);

            if (missasFiltradas.length === 0) {
                listaMissas.innerHTML = '<p class="info-vazia">Nenhuma missa deste tipo agendada.</p>';
                return;
            }

            let html = '';
            missasFiltradas.forEach(missa => {
                const dataFormatada = new Date(missa.data).toLocaleDateString('pt-BR');
                html += `
                    <div class="missa-item">
                        <h4>${missa.tipo}</h4>
                        <div class="missa-info">
                            <div>📅 <strong>Data:</strong> ${dataFormatada}</div>
                            <div>🕐 <strong>Hora:</strong> ${missa.hora}</div>
                        </div>
                        <div class="missa-info">
                            <div>📍 <strong>Local:</strong> ${missa.local}</div>
                            <div>👨‍⛪ <strong>Sacerdote:</strong> ${missa.sacerdote}</div>
                        </div>
                        ${missa.descricao ? `<div class="missa-descricao"><strong>Notas:</strong> ${missa.descricao}</div>` : ''}
                        <button class="btn-remover" onclick="removerMissa(${missa.id})">✕ Remover</button>
                    </div>
                `;
            });

            listaMissas.innerHTML = html;
        }

        // Exportar missas como CSV
        function exportarMissas() {
            if (missasAgendadas.length === 0) {
                alert('❌ Nenhuma missa agendada!');
                return;
            }

            let csv = 'Data,Hora,Tipo,Local,Sacerdote,Notas\n';
            
            missasAgendadas.forEach(missa => {
                const dataFormatada = new Date(missa.data).toLocaleDateString('pt-BR');
                csv += `"${dataFormatada}","${missa.hora}","${missa.tipo}","${missa.local}","${missa.sacerdote}","${missa.descricao || ''}"\n`;
            });

            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'missas-agendadas.csv';
            a.click();
            URL.revokeObjectURL(url);
        }

        // Carregar missas ao iniciar
        window.addEventListener('load', () => {
            exibirMissas();
        });
    </script>
</body>
</html>