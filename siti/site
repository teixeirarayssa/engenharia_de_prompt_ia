                    <div class="reza-texto">
                        <p>"A minh'alma engrandece o Senhor, e o meu espírito se alegra em Deus, meu Salvador; porque atentou na humildade da sua serva; pois eis que desde agora me chamará bem-aventurada toda a geração. Porque me fez grandes coisas o Poderoso; e santo é o seu nome. E a sua misericórdia é de geração em geração sobre aqueles que o temem."</p>
                    </div>
                    <button class="btn btn-small" onclick="favoritar('reza-magnificat')">❤️ Favoritar</button>
                </div>
            </div>
        </div>
    </section>

    <!-- SEÇÃO MISSAS -->
    <section id="missas" class="section">
        <div class="container">
            <h2>⛪ Organização de Missas</h2>
            <p class="subheading">Agende e organize as celebrações</p>

            <div class="missas-content">
                <div class="form-container">
                    <h3>Agendar Nova Missa</h3>
                    <form id="formMissa" onsubmit="agendarMissa(event)">
                        <div class="form-group">
                            <label for="dataMissa">📅 Data da Missa *</label>
                            <input type="date" id="dataMissa" required>
                        </div>

                        <div class="form-group">
                            <label for="horaMissa">🕐 Hora da Missa *</label>
                            <input type="time" id="horaMissa" required>
                        </div>

                        <div class="form-group">
                            <label for="tipoMissa">✝️ Tipo de Missa *</label>
                            <select id="tipoMissa" required>
                                <option value="">-- Selecione --</option>
                                <option value="Missa Dominical">Missa Dominical</option>
                                <option value="Missa de Semana">Missa de Semana</option>
                                <option value="Missa Festiva">Missa Festiva</option>
                                <option value="Missa de Defuntos">Missa de Defuntos</option>
                                <option value="Missa de Primeira Comunhão">Missa de Primeira Comunhão</option>
                                <option value="Missa de Casamento">Missa de Casamento</option>
                                <option value="Missa de Padroeiro">Missa de Padroeiro</option>
                                <option value="Missa Especial">Missa Especial</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="localMissa">📍 Local da Celebração *</label>
                            <input type="text" id="localMissa" placeholder="Igreja, Capela..." required>
                        </div>

                        <div class="form-group">
                            <label for="sacerdote">👨‍⛪ Sacerdote *</label>
                            <input type="text" id="sacerdote" placeholder="Nome do Sacerdote" required>
                        </div>

                        <div class="form-group">
                            <label for="descricaoMissa">📝 Notas (Opcional)</label>
                            <textarea id="descricaoMissa" placeholder="Adicione informações adicionais..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-full">✅ Agendar Missa</button>
                    </form>
                </div>

                <div class="list-container">
                    <h3>📋 Missas Agendadas</h3>

                    <div class="filter-buttons">
                        <button class="btn btn-filter" onclick="exibirMissas()">📊 Todas</button>
                        <button class="btn btn-filter" onclick="filtrarMissasPorTipo('Missa Dominical')">📅 Dominicais</button>
                        <button class="btn btn-filter" onclick="filtrarMissasPorTipo('Missa Festiva')">🎉 Festivas</button>
                        <button class="btn btn-filter" onclick="exportarMissas()">💾 Exportar CSV</button>
                    </div>

                    <div id="listaMissas" class="missas-list">
                        <p class="info-vazia">Nenhuma missa agendada.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <p>&copy; 2026 Portal Católico. Todos os direitos reservados. ✝️</p>
            <p>Um espaço de fé, oração e celebração</p>
        </div>
    </footer>

    <script>
        // Alternar seções
        function showSection(sectionId) {
            const sections = document.querySelectorAll('.section');
            sections.forEach(section => {
                section.classList.remove('active');
            });

            const selectedSection = document.getElementById(sectionId);
            if (selectedSection) {
                selectedSection.classList.add('active');
                window.scrollTo(0, 0);
            }
        }

        // Favoritar
        function favoritar(id) {
            const favoritos = JSON.parse(localStorage.getItem('favoritos')) || [];
            
            if (favoritos.includes(id)) {
                favoritos.splice(favoritos.indexOf(id), 1);
                alert('❌ Removido dos favoritos!');
            } else {
                favoritos.push(id);
                alert('✅ Adicionado aos favoritos!');
            }
            
            localStorage.setItem('favoritos', JSON.stringify(favoritos));
        }

        // Agendar Missa
        function agendarMissa(event) {
            event.preventDefault();

            const dataMissa = document.getElementById('dataMissa').value;
            const horaMissa = document.getElementById('horaMissa').value;
            const localMissa = document.getElementById('localMissa').value;
            const sacerdote = document.getElementById('sacerdote').value;
            const tipoMissa = document.getElementById('tipoMissa').value;
            const descricaoMissa = document.getElementById('descricaoMissa').value;

            if (!dataMissa || !horaMissa || !localMissa || !sacerdote || !tipoMissa) {
                alert('⚠️ Por favor, preencha todos os campos obrigatórios!');
                return;
            }

            const dataFormatada = new Date(dataMissa).toLocaleDateString('pt-BR');

            const missa = {
                id: Date.now(),
                data: dataMissa,
                dataFormatada: dataFormatada,
                hora: horaMissa,
                local: localMissa,
                sacerdote: sacerdote,
                tipo: tipoMissa,
                descricao: descricaoMissa
            };

            const missas = JSON.parse(localStorage.getItem('missas')) || [];
            missas.push(missa);
            missas.sort((a, b) => new Date(a.data) - new Date(b.data));

            localStorage.setItem('missas', JSON.stringify(missas));

            document.getElementById('formMissa').reset();
            exibirMissas();
            alert('✅ Missa agendada com sucesso!');
        }

        // Exibir Missas
        function exibirMissas() {
            const listaMissas = document.getElementById('listaMissas');
            const missas = JSON.parse(localStorage.getItem('missas')) || [];

            if (missas.length === 0) {
                listaMissas.innerHTML = '<p class="info-vazia">📭 Nenhuma missa agendada ainda.</p>';
                return;
            }

            let html = '';
            missas.forEach((missa) => {
                html += `
                    <div class="missa-item">
                        <h4>📅 ${missa.dataFormatada} às ${missa.hora}</h4>
                        <div class="missa-info">
                            <div><strong>✝️ Tipo:</strong> ${missa.tipo}</div>
                            <div><strong>👨‍⛪ Sacerdote:</strong> ${missa.sacerdote}</div>
                            <div colspan="2"><strong>📍 Local:</strong> ${missa.local}</div>
                        </div>
                        ${missa.descricao ? `<div class="missa-descricao"><strong>📝 Notas:</strong> ${missa.descricao}</div>` : ''}
                        <button class="btn btn-remover" onclick="removerMissa(${missa.id})">🗑️ Remover</button>
                    </div>
                `;
            });

            listaMissas.innerHTML = html;
        }

        // Remover Missa
        function removerMissa(id) {
            if (confirm('🚨 Tem certeza que deseja remover esta missa?')) {
                let missas = JSON.parse(localStorage.getItem('missas')) || [];
                missas = missas.filter(missa => missa.id !== id);
                localStorage.setItem('missas', JSON.stringify(missas));
                exibirMissas();
                alert('✅ Missa removida!');
            }
        }

        // Toggle Accordion
        function toggleAccordion(header) {
            const item = header.parentElement;
            
            document.querySelectorAll('.accordion-item.active').forEach(el => {
                if (el !== item) {
                    el.classList.remove('active');
                    el.querySelector('.accordion-header').classList.remove('active');
                }
            });

            item.classList.toggle('active');
            header.classList.toggle('active');
        }

        // Carregar dados ao abrir
        document.addEventListener('DOMContentLoaded', function() {
            showSection('home');
            exibirMissas();

            const hoje = new Date().toISOString().split('T')[0];
            const dataMissaInput = document.getElementById('dataMissa');
            if (dataMissaInput) {
                dataMissaInput.min = hoje;
            }
        });

        // Pesquisar Músicas
        function pesquisarMusica() {
            const searchTerm = document.getElementById('searchMusica').value.toLowerCase();
            const cards = document.querySelectorAll('#gridMusicas .card');

            cards.forEach(card => {
                const titulo = card.querySelector('h3').textContent.toLowerCase();
                const descricao = card.querySelector('p').textContent.toLowerCase();

                if (titulo.includes(searchTerm) || descricao.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Filtrar Missas por Tipo
        function filtrarMissasPorTipo(tipo) {
            const missas = JSON.parse(localStorage.getItem('missas')) || [];
            const listaMissas = document.getElementById('listaMissas');

            let missasFiltradas = missas;
            if (tipo !== 'todas') {
                missasFiltradas = missas.filter(missa => missa.tipo === tipo);
            }

            if (missasFiltradas.length === 0) {
                listaMissas.innerHTML = '<p class="info-vazia">🔍 Nenhuma missa encontrada neste tipo.</p>';
                return;
            }

            let html = '';
            missasFiltradas.forEach((missa) => {
                html += `
                    <div class="missa-item">
                        <h4>📅 ${missa.dataFormatada} às ${missa.hora}</h4>
                        <div class="missa-info">
                            <div><strong>✝️ Tipo:</strong> ${missa.tipo}</div>
                            <div><strong>👨‍⛪ Sacerdote:</strong> ${missa.sacerdote}</div>
                            <div colspan="2"><strong>📍 Local:</strong> ${missa.local}</div>
                        </div>
                        ${missa.descricao ? `<div class="missa-descricao"><strong>📝 Notas:</strong> ${missa.descricao}</div>` : ''}
                        <button class="btn btn-remover" onclick="removerMissa(${missa.id})">🗑️ Remover</button>
                    </div>
                `;
            });

            listaMissas.innerHTML = html;
        }

        // Exportar Missas como CSV
        function exportarMissas() {
            const missas = JSON.parse(localStorage.getItem('missas')) || [];

            if (missas.length === 0) {
                alert('⚠️ Nenhuma missa para exportar!');
                return;
            }

            let csv = 'Data,Hora,Local,Sacerdote,Tipo,Descrição\n';
            missas.forEach(missa => {
                csv += `"${missa.dataFormatada}","${missa.hora}","${missa.local}","${missa.sacerdote}","${missa.tipo}","${missa.descricao || ''}"\n`;
            });

            const element = document.createElement('a');
            element.setAttribute('href', 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv));
            element.setAttribute('download', 'missas.csv');
            element.style.display = 'none';
            document.body.appendChild(element);
            element.click();
            document.body.removeChild(element);

            alert('✅ Missas exportadas com sucesso!');
        }
    </script>
</body>
</html>
